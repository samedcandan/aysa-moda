# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# scripts containing API keys or user seeding/management
scripts/setup-vercel-env.js
scripts/manage-users.js
scripts/test-tryon.js

# Android / Capacitor
*.aab
*.apk
*.jks
*.keystore
android/.gradle/
android/app/build/
android/build/
android/app/src/main/assets/capacitor.config.json
android/app/src/main/assets/public/
google-services.json

